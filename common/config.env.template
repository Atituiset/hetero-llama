# Hetero-LLaMA 共享配置模板
# 各 mode 的 config.env 可 source 本文件后覆盖特定值

# -----------------------------
# 节点地址（按实际环境修改）
# -----------------------------

# GPU PC（Host，运行 llama-completion，带 CUDA）
GPU_PC_IP="${GPU_PC_IP:-192.168.1.10}"
GPU_PC_USER="${GPU_PC_USER:-atituiset}"

# 当前机器（RPC Worker，CPU 后端，WSL / Linux）
CURRENT_REAL_IP="${CURRENT_REAL_IP:-172.26.88.148}"
CURRENT_IP="${CURRENT_IP:-${CURRENT_REAL_IP}}"
CURRENT_PORT="${CURRENT_PORT:-50053}"

# Mate 40 Pro（RPC Worker，CPU 后端）
PHONE_REAL_HOST="${PHONE_REAL_HOST:-192.168.1.7}"
PHONE_HOST="${PHONE_HOST:-${PHONE_REAL_HOST}}"
PHONE_PORT="${PHONE_PORT:-50052}"

# -----------------------------
# 隧道模式
# -----------------------------
TUNNEL_MODE="${TUNNEL_MODE:-0}"
if [ "${TUNNEL_MODE}" == "1" ]; then
    CURRENT_IP="127.0.0.1"
    PHONE_HOST="127.0.0.1"
fi

# -----------------------------
# llama.cpp 构建路径
# -----------------------------
GPU_PC_LLAMA_CPP_DIR="${GPU_PC_LLAMA_CPP_DIR:-${HOME}/projects/gpu-cpu-phone-test/llama.cpp}"
GPU_PC_BUILD_DIR="${GPU_PC_BUILD_DIR:-${GPU_PC_LLAMA_CPP_DIR}/build-cuda-rpc}"

CURRENT_LLAMA_CPP_DIR="${CURRENT_LLAMA_CPP_DIR:-${HOME}/Projects/gpu-cpu-phone-test/llama.cpp}"
CURRENT_BUILD_DIR="${CURRENT_BUILD_DIR:-${CURRENT_LLAMA_CPP_DIR}/build-rpc}"

PHONE_LLAMA_CPP_DIR="${PHONE_LLAMA_CPP_DIR:-${HOME}/Projects/gpu-cpu-phone-test/llama.cpp}"
PHONE_BUILD_DIR="${PHONE_BUILD_DIR:-${PHONE_LLAMA_CPP_DIR}/build-rpc}"

# -----------------------------
# 模型与缓存
# -----------------------------
MODEL_PATH="${MODEL_PATH:-${HOME}/models/qwen2-0.5b-instruct-q4_0.gguf}"
CACHE_DIR="${CACHE_DIR:-${HOME}/.cache/llama.cpp/rpc}"

# -----------------------------
# 默认推理参数
# -----------------------------
DEFAULT_NGL="${DEFAULT_NGL:-20}"
DEFAULT_PROMPT="${DEFAULT_PROMPT:-你好}"
DEFAULT_N="${DEFAULT_N:-5}"
