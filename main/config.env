# Hetero-LLaMA 三机推理拓扑配置
# 在所有脚本开头 source 使用

# -----------------------------
# 节点地址
# -----------------------------

# GPU PC（Host，运行 llama-completion，带 CUDA）
GPU_PC_IP="192.168.1.10"
GPU_PC_USER="atituiset"

# 当前机器（RPC Worker，CPU 后端）
# WSL 自动检测可能拿到其他网卡，这里写死当前 WSL 的局域网 IP
CURRENT_REAL_IP="172.26.88.148"
CURRENT_IP="${CURRENT_REAL_IP}"
CURRENT_PORT="50053"

# Mate 40 Pro（RPC Worker，CPU 后端）
PHONE_REAL_HOST="192.168.1.7"
PHONE_HOST="${PHONE_REAL_HOST}"
PHONE_PORT="50052"

# -----------------------------
# 隧道模式（解决 WSL2 / Android 入站网络问题）
# -----------------------------
# 说明：
#   - 0：直连模式。Host 直接通过 CURRENT_IP/PHONE_HOST 连接 Worker。
#     要求 Worker 的 IP:PORT 能从 Host 直接访问。
#   - 1：隧道模式。当前机器作为跳板，通过 SSH 反向隧道把 Worker 暴露给 Host。
#     适用于 WSL2（默认 NAT 入站受限）或 Android（Termux 入站受限）。
# 使用隧道模式时，在当前机器执行 ./setup_tunnels.sh，再于 GPU PC 执行 ./run_gpu_host.sh。
TUNNEL_MODE="${TUNNEL_MODE:-0}"
if [ "${TUNNEL_MODE}" == "1" ]; then
    CURRENT_IP="127.0.0.1"
    PHONE_HOST="127.0.0.1"
fi

# -----------------------------
# llama.cpp 构建路径
# -----------------------------

# GPU PC 上 CUDA + RPC 构建目录
GPU_PC_LLAMA_CPP_DIR="${HOME}/projects/gpu-cpu-phone-test/llama.cpp"
GPU_PC_BUILD_DIR="${GPU_PC_LLAMA_CPP_DIR}/build-cuda-rpc"

# 当前机器上 RPC Server 构建目录
CURRENT_LLAMA_CPP_DIR="${HOME}/Projects/gpu-cpu-phone-test/llama.cpp"
CURRENT_BUILD_DIR="${CURRENT_LLAMA_CPP_DIR}/build-rpc"

# 手机上 RPC Server 构建目录
# 注意：该路径在手机上求值，${HOME} 指手机中的 home 目录（如 proot 中的 /root）
PHONE_LLAMA_CPP_DIR="${HOME}/Projects/gpu-cpu-phone-test/llama.cpp"
PHONE_BUILD_DIR="${PHONE_LLAMA_CPP_DIR}/build-rpc"

# -----------------------------
# 模型与缓存
# -----------------------------

MODEL_PATH="${HOME}/models/qwen2-0.5b-instruct-q4_0.gguf"
CACHE_DIR="${HOME}/.cache/llama.cpp/rpc"

# -----------------------------
# 默认推理参数
# -----------------------------

DEFAULT_NGL="20"
DEFAULT_PROMPT="你好"
DEFAULT_N="5"
